# Copy this file to .env and fill in your real values later.
# .env is not committed to git.

# API server port (default 3002 so Nuxt can use 3000)
PORT=3002

# OpenRouteService — for route generation (step 4+)
OPENROUTESERVICE_API_KEY=

# Supabase — for database and auth (step 7+)
SUPABASE_URL=
SUPABASE_ANON_KEY=
