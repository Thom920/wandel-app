# Kopieer naar .env — .env gaat NIET naar GitHub

# Node API (achterkant) — NIET dezelfde poort als Nuxt!
PORT=3002

# Gratis key: https://openrouteservice.org/dev/#/signup
OPENROUTESERVICE_API_KEY=

# Waar de website de API zoekt
# Lokaal (2 terminals): http://localhost:3002 — zelfde poort als PORT
# Vercel of 1 terminal: leeg laten → /api/route op dezelfde site
NUXT_PUBLIC_API_BASE=http://localhost:3002

# Supabase — stap 7+8 (zie docs/07 en docs/08-supabase-auth.md)
# Alleen anon key in de website; NOOIT service_role in de frontend.
# Anonymous sign-ins moet AAN in Supabase-dashboard.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Optioneel: sommige tools verwachten SUPABASE_KEY (zelfde waarde als ANON_KEY)
# SUPABASE_KEY=
